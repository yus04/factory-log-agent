# Foundry Local で利用するモデルのエイリアス (ツール呼び出し対応モデルを推奨)
FOUNDRY_LOCAL_MODEL=phi-4-mini

# 解析対象の工場ログ CSV (プロジェクトルートからの相対パス、または絶対パス)
FACTORY_LOG_CSV=factory-log-data/factory_equipment_log.csv

# A2A サーバーの待ち受け設定
A2A_HOST=0.0.0.0
A2A_PORT=9999
# クライアント/エージェントカードに記載する公開 URL
A2A_PUBLIC_URL=http://localhost:9999/
